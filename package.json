{
  "name": "citro-eighty",
  "type": "module",
  "scripts": {
    "start": "bin/server index",
    "start:worker": "bin/server worker",
    "manage": "bin/server manage",
    "build": "pnpm run build:tsc && pnpm run build:client && pnpm build:server",
    "build:tsc": "tsc",
    "build:client": "NODE_ENV=production vite build --outDir dist/client",
    "build:server": "NODE_ENV=production vite build --outDir dist/server --ssr src/entry-server.tsx",
    "lint": "eslint",
    "format": "prettier --write '**/*.{md,js,mjs,ts,mts,tsx,css,scss,html,yml}'",
    "test": "NODE_ENV=test DOTENV_CONFIG_PATH=.env.test vitest",
    "generate-types": "bin/server manage generate-db && pnpm run lint --fix && pnpm run format"
  },
  "dependencies": {
    "@devmoods/config": "^0.2.0",
    "@devmoods/express-extras": "^0.66.1",
    "@devmoods/fetch": "^4.2.0",
    "@devmoods/postgres-admin": "^0.12.0",
    "@devmoods/ui": "^2.11.0",
    "@standard-schema/spec": "^1.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "arktype": "2.1.23",
    "dotenv": "^17.2.3",
    "express": "4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^2.0.5",
    "react-router": "^7.9.4"
  },
  "devDependencies": {
    "@devmoods/eslint-config": "^2.14.0",
    "@types/node": "^24.8.1",
    "eslint": "^9.37.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.10"
  },
  "prettier": {
    "singleQuote": true
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "bcrypt",
      "argon2",
      "@sentry-internal/node-cpu-profiler"
    ],
    "updateConfig": {
      "ignoreDependencies": [
        "express"
      ]
    }
  }
}
