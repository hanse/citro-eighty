{
  "name": "citro-eighty",
  "type": "module",
  "scripts": {
    "start": "bin/server index",
    "start:worker": "bin/server worker",
    "manage": "bin/server manage",
    "build": "pnpm run build:tsc && pnpm run build:client && pnpm build:server",
    "build:tsc": "tsc",
    "build:client": "NODE_ENV=production vite build --outDir dist/client",
    "build:server": "NODE_ENV=production vite build --outDir dist/server --ssr src/entry-server.tsx",
    "lint": "eslint",
    "format": "prettier --write '**/*.{md,js,mjs,ts,mts,tsx,css,scss,html,yml}'",
    "test": "NODE_ENV=test DOTENV_CONFIG_PATH=.env.test vitest",
    "generate-types": "bin/server manage generate-db && pnpm run lint --fix && pnpm run format"
  },
  "dependencies": {
    "@devmoods/config": "^0.2.1",
    "@devmoods/express-extras": "^0.72.1",
    "@devmoods/fetch": "^4.3.0",
    "@devmoods/postgres-admin": "^0.17.1",
    "@devmoods/ui": "^2.16.0",
    "@standard-schema/spec": "^1.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "arktype": "2.2.0",
    "dotenv": "^17.4.1",
    "express": "4.22.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.0"
  },
  "devDependencies": {
    "@devmoods/eslint-config": "^2.16.0",
    "@types/node": "^25.5.2",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "@vitejs/plugin-react": "^6.0.1"
  },
  "prettier": {
    "singleQuote": true
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "bcrypt",
      "argon2",
      "@sentry-internal/node-cpu-profiler"
    ],
    "updateConfig": {
      "ignoreDependencies": [
        "express",
        "eslint"
      ]
    }
  }
}
